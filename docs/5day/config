# 5DayDocs Configuration
# Edit freely. Changes preserved across updates. Format: KEY=VALUE

# AI CLI binary for exec mode (claude is verified; any other name falls back
# to a generic prompt passthrough). Inside an AI session, MODE=emit is used
# and this is ignored. See MODE below.
CLI=claude

# Capability tier for this install: claude-code | cursor | openai | generic.
# Set by setup.sh from your provider choice. Scripts read it (via
# fiveday_ai_tier) to use full orchestration on claude-code and degrade
# gracefully elsewhere. Empty = inferred from CLI above. See the capability
# matrix in docs/5day/ai/provider-capabilities.md.
PROVIDER=claude-code

# How AI commands deliver their prompt:
#   emit  — print the prompt for the agent you're already in (Claude Code,
#           Cursor, etc.) to run — no nested CLI, works with any AI
#   exec  — spawn the CLI binary above (for a plain terminal, loops, CI)
#   (empty) — auto: emit inside an agent session, otherwise exec
MODE=

# Default model. Empty = let the CLI pick its own default.
MODEL_DEFAULT=

# Per-script models. Empty = fall back to MODEL_DEFAULT.
MODEL_PLAN=
MODEL_DEFINE=
MODEL_FIND=
MODEL_SPLIT=
MODEL_SPRINT=
MODEL_TASKS=
MODEL_CODE_AUDIT=
MODEL_EXCELLENCE=
MODEL_AUDIT=
MODEL_TRIAGE=
MODEL_REVIEW_SPRINT=
MODEL_THINK=
MODEL_DRIFT=

# Budget caps per invocation (USD). Empty = no cap.
BUDGET_TASKS=5.00
BUDGET_AUDIT=3.00

# Code audit max iterative passes
AUDIT_MAX_PASSES=2
